generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  targets Target[]
  tokens  RefreshToken[]
  scans   Scan[]
  findings Finding[]
}

model RefreshToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique
  userId      String
  tokenFamily String
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Target {
  id        String   @id @default(uuid())
  domain    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  scans    Scan[]
  findings Finding[]

  @@unique([domain, userId])
}

model Scan {
  id        String   @id @default(uuid())
  targetId  String
  userId    String
  status    String
  createdAt DateTime @default(now())

  target Target @relation(fields: [targetId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  results  ScanResult[]
  findings Finding[]
}

model ScanResult {
  id        String   @id @default(uuid())
  scanId    String
  type      String
  data      Json
  createdAt DateTime @default(now())

  scan Scan @relation(fields: [scanId], references: [id])
}

model Finding {
  id        String   @id @default(uuid())
  scanId    String
  targetId  String
  userId    String

  category    String
  title       String
  description String

  severity   String
  weight     Float
  exposure   Float
  mitigation Float

  confidence String
  impact     String

  evidence Json

  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scan   Scan   @relation(fields: [scanId], references: [id])
  target Target @relation(fields: [targetId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}
